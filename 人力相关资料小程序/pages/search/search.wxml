<view class="container">
  <view class="search-header">
    <view class="search-input-wrapper">
      <text class="search-icon-text">🔍</text>
      <input class="search-input" placeholder="搜索资料名称..." value="{{keyword}}" bindinput="onInput" bindconfirm="onSearch" confirm-type="search" focus="{{true}}" />
      <text class="clear-icon" bindtap="clearKeyword" wx:if="{{keyword}}">✕</text>
    </view>
    <text class="cancel-btn" bindtap="goBack">取消</text>
  </view>

  <view class="result-count" wx:if="{{searched}}">
    <text>找到 {{resultList.length}} 个相关资料</text>
  </view>

  <view class="result-list" wx:if="{{resultList.length > 0}}">
    <view class="file-item" wx:for="{{resultList}}" wx:key="id" bindtap="goToFile" data-file="{{item}}">
      <view class="file-icon-wrapper">
        <view class="type-badge {{item.type}}">{{item.type}}</view>
      </view>
      <view class="file-info">
        <text class="file-title">{{item.title}}</text>
        <text class="file-meta">{{item.size}} · {{item.uploadTime}}</text>
      </view>
      <text class="arrow-icon">›</text>
    </view>
  </view>

  <view class="empty-result" wx:if="{{searched && resultList.length === 0}}">
    <text class="empty-icon">📭</text>
    <text class="empty-text">未找到相关资料</text>
    <text class="empty-hint">换个关键词试试吧</text>
  </view>
</view>
