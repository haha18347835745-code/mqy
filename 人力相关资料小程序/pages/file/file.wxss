.container {
  min-height: 100vh;
  background-color: #f5f5f5;
  display: flex;
  flex-direction: column;
}

.file-header {
  background-color: #fff;
  padding: 30rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.file-title {
  flex: 1;
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-right: 20rpx;
}

.file-type-badge {
  background-color: #1890ff;
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
}

.file-type-badge text {
  color: #fff;
  font-size: 24rpx;
}

.content-wrapper {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 30rpx;
}

.image-preview {
  width: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.preview-image {
  max-width: 100%;
  max-height: 70vh;
  border-radius: 12rpx;
}

.document-preview {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx;
  background-color: #fff;
  border-radius: 16rpx;
}

.doc-icon-wrapper {
  width: 160rpx;
  height: 160rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: #f5f5f5;
  border-radius: 20rpx;
  margin-bottom: 30rpx;
}

.doc-icon-emoji {
  font-size: 80rpx;
}

.doc-name {
  font-size: 30rpx;
  color: #333;
  text-align: center;
  margin-bottom: 16rpx;
  word-break: break-all;
}

.doc-tip {
  font-size: 26rpx;
  color: #999;
}

.action-bar {
  display: flex;
  justify-content: space-around;
  padding: 30rpx;
  background-color: #fff;
  padding-bottom: calc(30rpx + env(safe-area-inset-bottom));
}

.action-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  background-color: #fff;
  padding: 16rpx 30rpx;
  border: none;
  border-radius: 0;
  line-height: 1;
}

.action-btn::after {
  border: none;
}

.action-icon {
  font-size: 44rpx;
  margin-bottom: 8rpx;
}

.action-text {
  font-size: 24rpx;
  color: #666;
}

.admin-action {
  padding: 20rpx 30rpx;
  background-color: #fff;
  border-top: 1rpx solid #f0f0f0;
}

.delete-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 88rpx;
  background-color: #fff;
  border: 2rpx solid #ff4d4f;
  border-radius: 12rpx;
  color: #ff4d4f;
  font-size: 28rpx;
}

.delete-btn::after {
  border: none;
}

.delete-icon {
  font-size: 32rpx;
  margin-right: 10rpx;
}
