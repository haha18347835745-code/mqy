<view class="container">
  <view class="folder-header">
    <text class="folder-icon">{{folderIcon}}</text>
    <text class="folder-name">{{folderName}}</text>
    <text class="file-count">{{fileList.length}} 个文件</text>
  </view>

  <view class="file-list" wx:if="{{fileList.length > 0}}">
    <view class="file-item {{isAdmin ? 'admin' : ''}}" wx:for="{{fileList}}" wx:key="_id">
      <view class="file-main" bindtap="goToFile" data-file="{{item}}">
        <view class="file-icon-wrapper">
          <view class="type-badge {{item.type}}">{{item.type}}</view>
        </view>
        <view class="file-info">
          <text class="file-title">{{item.title}}</text>
          <text class="file-meta">{{item.size}} · {{item.uploadTime}}</text>
        </view>
        <text class="arrow-icon">›</text>
      </view>
      <view class="file-delete" wx:if="{{isAdmin}}" bindtap="deleteFile" data-id="{{item._id || item.id}}">
        <text>🗑️</text>
      </view>
    </view>
  </view>

  <view class="empty-result" wx:if="{{fileList.length === 0}}">
    <text class="empty-icon">📁</text>
    <text class="empty-text">该分类暂无文件</text>
  </view>
</view>
