<view class="container">
  <view class="profile-header">
    <view class="avatar-wrapper">
      <text class="avatar-emoji">{{isAdmin ? '👨‍💼' : '👤'}}</text>
    </view>
    <text class="username">{{isAdmin ? '管理员' : '游客用户'}}</text>
    <text class="user-tip">{{isAdmin ? '可上传和管理资料' : '仅可查看资料'}}</text>
  </view>

  <view class="menu-list">
    <block wx:if="{{isAdmin}}">
      <view class="menu-item" bindtap="goToUpload">
        <view class="menu-left">
          <text class="menu-icon">📤</text>
          <text class="menu-text">上传资料</text>
        </view>
        <text class="arrow-icon">›</text>
      </view>
    </block>
    <block wx:else>
      <view class="menu-item" bindtap="showLoginModal">
        <view class="menu-left">
          <text class="menu-icon">🔐</text>
          <text class="menu-text">管理员登录</text>
        </view>
        <text class="arrow-icon">›</text>
      </view>
    </block>
  </view>

  <view class="folder-management" wx:if="{{isAdmin}}">
    <view class="section-header">
      <text class="section-title">文件夹管理</text>
      <text class="add-folder-btn" bindtap="showAddFolderModal">➕ 添加</text>
    </view>
    <view class="folder-list">
      <view class="folder-item" wx:for="{{folders}}" wx:key="_id">
        <view class="folder-info" bindtap="goToFolder" data-folder="{{item}}">
          <text class="folder-emoji">{{item.icon}}</text>
          <text class="folder-name">{{item.name}}</text>
        </view>
        <view class="folder-actions">
          <text class="delete-folder-btn" bindtap="deleteFolder" data-id="{{item._id}}">🗑️</text>
        </view>
      </view>
    </view>
  </view>

  <view class="menu-list">
    <view class="menu-item">
      <view class="menu-left">
        <text class="menu-icon">📜</text>
        <text class="menu-text">浏览历史</text>
      </view>
      <text class="arrow-icon">›</text>
    </view>
    <view class="menu-item">
      <view class="menu-left">
        <text class="menu-icon">⭐</text>
        <text class="menu-text">我的收藏</text>
      </view>
      <text class="arrow-icon">›</text>
    </view>
  </view>

  <view class="menu-list">
    <view class="menu-item">
      <view class="menu-left">
        <text class="menu-icon">ℹ️</text>
        <text class="menu-text">关于我们</text>
      </view>
      <text class="arrow-icon">›</text>
    </view>
    <block wx:if="{{isAdmin}}">
      <view class="menu-item" bindtap="logout">
        <view class="menu-left">
          <text class="menu-icon">🚪</text>
          <text class="menu-text">退出登录</text>
        </view>
        <text class="arrow-icon">›</text>
      </view>
    </block>
  </view>

  <view class="app-info">
    <text class="version">知识库检索 v1.0.0</text>
  </view>

  <view class="login-modal" wx:if="{{showLogin}}">
    <view class="modal-mask" bindtap="hideLoginModal"></view>
    <view class="modal-content">
      <view class="modal-title">管理员登录</view>
      <input class="modal-input" password type="text" placeholder="请输入管理员密码" bindinput="onPasswordInput" />
      <view class="modal-buttons">
        <button class="modal-btn cancel" bindtap="hideLoginModal">取消</button>
        <button class="modal-btn confirm" bindtap="doLogin">登录</button>
      </view>
    </view>
  </view>

  <view class="add-folder-modal" wx:if="{{showAddFolder}}">
    <view class="modal-mask" bindtap="hideAddFolderModal"></view>
    <view class="modal-content">
      <view class="modal-title">添加文件夹</view>
      <input class="modal-input" placeholder="请输入文件夹名称" bindinput="onFolderNameInput" />
      <view class="icon-select">
        <view class="icon-option {{selectedIcon === item ? 'selected' : ''}}" wx:for="{{iconOptions}}" wx:key="*this" bindtap="selectIcon" data-icon="{{item}}">
          <text>{{item}}</text>
        </view>
      </view>
      <view class="modal-buttons">
        <button class="modal-btn cancel" bindtap="hideAddFolderModal">取消</button>
        <button class="modal-btn confirm" bindtap="addFolder">添加</button>
      </view>
    </view>
  </view>
</view>
