.container {
  min-height: 100vh;
  background-color: #f5f5f5;
}

.profile-header {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 30rpx;
  background: linear-gradient(135deg, #1890ff 0%, #40a9ff 100%);
}

.avatar-wrapper {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  background-color: rgba(255, 255, 255, 0.2);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 20rpx;
}

.avatar-emoji {
  font-size: 70rpx;
}

.username {
  font-size: 36rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 10rpx;
}

.user-tip {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.8);
}

.menu-list {
  background-color: #fff;
  margin: 20rpx;
  border-radius: 16rpx;
  padding: 0 20rpx;
}

.menu-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 30rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-left {
  display: flex;
  align-items: center;
}

.menu-icon {
  font-size: 36rpx;
  margin-right: 20rpx;
}

.menu-text {
  font-size: 28rpx;
  color: #333;
}

.arrow-icon {
  font-size: 36rpx;
  color: #ccc;
}

.folder-management {
  background-color: #fff;
  margin: 20rpx;
  border-radius: 16rpx;
  padding: 30rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
}

.add-folder-btn {
  font-size: 28rpx;
  color: #1890ff;
}

.folder-list {
  display: flex;
  flex-direction: column;
}

.folder-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.folder-item:last-child {
  border-bottom: none;
}

.folder-info {
  display: flex;
  align-items: center;
  flex: 1;
}

.folder-emoji {
  font-size: 40rpx;
  margin-right: 20rpx;
}

.folder-name {
  font-size: 28rpx;
  color: #333;
}

.folder-actions {
  display: flex;
  align-items: center;
}

.delete-folder-btn {
  font-size: 32rpx;
  padding: 10rpx;
}

.app-info {
  display: flex;
  justify-content: center;
  padding: 40rpx;
}

.version {
  font-size: 24rpx;
  color: #999;
}

.login-modal,
.add-folder-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 1000;
}

.modal-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
}

.modal-content {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 600rpx;
  background-color: #fff;
  border-radius: 16rpx;
  padding: 40rpx;
}

.modal-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  text-align: center;
  margin-bottom: 30rpx;
}

.modal-input {
  width: 100%;
  height: 80rpx;
  background-color: #f5f5f5;
  border-radius: 12rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  margin-bottom: 30rpx;
  box-sizing: border-box;
}

.icon-select {
  display: flex;
  flex-wrap: wrap;
  margin-bottom: 30rpx;
}

.icon-option {
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  border-radius: 12rpx;
  margin: 10rpx;
  background-color: #f5f5f5;
}

.icon-option.selected {
  background-color: #e6f7ff;
  border: 2rpx solid #1890ff;
}

.modal-buttons {
  display: flex;
  justify-content: space-between;
}

.modal-btn {
  flex: 1;
  height: 80rpx;
  border-radius: 12rpx;
  font-size: 28rpx;
  border: none;
  line-height: 80rpx;
}

.modal-btn.cancel {
  background-color: #f5f5f5;
  color: #666;
  margin-right: 20rpx;
}

.modal-btn.confirm {
  background: linear-gradient(135deg, #1890ff 0%, #40a9ff 100%);
  color: #fff;
}

.modal-btn::after {
  border: none;
}
