.container {
  min-height: 100vh;
  background-color: #f5f5f5;
}

.upload-section {
  background-color: #fff;
  padding: 40rpx 30rpx;
  margin-bottom: 20rpx;
}

.upload-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 16rpx;
}

.upload-tip {
  font-size: 26rpx;
  color: #999;
  margin-bottom: 40rpx;
}

.upload-box {
  width: 100%;
  height: 300rpx;
  border: 2rpx dashed #d9d9d9;
  border-radius: 16rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background-color: #fafafa;
}

.upload-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.upload-text {
  font-size: 28rpx;
  color: #666;
}

.file-list {
  background-color: #fff;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.selected-file {
  display: flex;
  align-items: center;
  padding: 20rpx;
  background-color: #f5f5f5;
  border-radius: 8rpx;
}

.file-icon-wrapper {
  width: 80rpx;
  height: 80rpx;
  background-color: #e6f7ff;
  border-radius: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.file-type-emoji {
  font-size: 40rpx;
}

.file-info {
  flex: 1;
  margin-left: 20rpx;
}

.file-name {
  font-size: 28rpx;
  color: #333;
  display: block;
}

.file-size {
  font-size: 24rpx;
  color: #999;
  display: block;
  margin-top: 8rpx;
}

.remove-icon {
  width: 50rpx;
  height: 50rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  color: #999;
}

.folder-section {
  background-color: #fff;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
}

.folder-list {
  display: flex;
  flex-wrap: wrap;
}

.folder-item {
  width: 25%;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx 0;
  box-sizing: border-box;
}

.folder-emoji {
  font-size: 50rpx;
  margin-bottom: 10rpx;
}

.folder-name {
  font-size: 24rpx;
  color: #333;
  text-align: center;
}

.folder-item.selected .folder-emoji,
.folder-item.selected .folder-name {
  color: #1890ff;
}

.folder-item.selected {
  background-color: #e6f7ff;
  border-radius: 8rpx;
}

.upload-btn-wrapper {
  background-color: #fff;
  padding: 30rpx;
}

.title-input {
  width: 100%;
  height: 80rpx;
  border: 2rpx solid #e5e5e5;
  border-radius: 8rpx;
  padding: 0 20rpx;
  margin-bottom: 20rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.submit-btn {
  width: 100%;
  height: 80rpx;
  background: linear-gradient(135deg, #1890ff 0%, #40a9ff 100%);
  color: #fff;
  border-radius: 40rpx;
  font-size: 30rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.history-section {
  background-color: #fff;
  padding: 30rpx;
}

.history-list {
  margin-top: 20rpx;
}

.history-item {
  display: flex;
  align-items: center;
  padding: 20rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.history-item:last-child {
  border-bottom: none;
}

.history-icon-wrapper {
  width: 80rpx;
  height: 80rpx;
  background-color: #f5f5f5;
  border-radius: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.history-icon {
  font-size: 40rpx;
}

.history-info {
  flex: 1;
  margin-left: 20rpx;
}

.history-title {
  font-size: 28rpx;
  color: #333;
  display: block;
}

.history-time {
  font-size: 24rpx;
  color: #999;
  display: block;
  margin-top: 8rpx;
}

.history-status {
  font-size: 24rpx;
  padding: 8rpx 16rpx;
  border-radius: 4rpx;
}

.history-status.success {
  color: #52c41a;
  background-color: #f6ffed;
  border: 1rpx solid #b7eb8f;
}
