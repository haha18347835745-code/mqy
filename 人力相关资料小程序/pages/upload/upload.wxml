<view class="container">
  <view class="upload-section">
    <view class="upload-title">选择文件上传</view>
    <view class="upload-tip">支持 PDF、Word、Excel、图片等文件</view>
    
    <view class="upload-box" bindtap="chooseFile">
      <text class="upload-icon">➕</text>
      <text class="upload-text">点击选择文件</text>
    </view>
  </view>

  <view class="file-list" wx:if="{{selectedFile}}">
    <view class="selected-file">
      <view class="file-icon-wrapper">
        <text class="file-type-emoji">{{getTypeEmoji(selectedFile.type)}}</text>
      </view>
      <view class="file-info">
        <text class="file-name">{{selectedFile.name}}</text>
        <text class="file-size">{{selectedFile.size}}</text>
      </view>
      <text class="remove-icon" bindtap="removeFile">✕</text>
    </view>
  </view>

  <view class="folder-section" wx:if="{{selectedFile}}">
    <view class="section-title">选择分类文件夹</view>
    <view class="folder-list">
      <view class="folder-item {{selectedFolderId === item._id ? 'selected' : ''}}" wx:for="{{folders}}" wx:key="_id" bindtap="selectFolder" data-id="{{item._id}}">
        <text class="folder-emoji">{{item.icon}}</text>
        <text class="folder-name">{{item.name}}</text>
      </view>
    </view>
  </view>

  <view class="upload-btn-wrapper" wx:if="{{selectedFile}}">
    <input class="title-input" placeholder="请输入文件标题" value="{{fileTitle}}" bindinput="onTitleInput" />
    <button class="submit-btn" bindtap="submitUpload">确认上传</button>
  </view>

  <view class="history-section" wx:if="{{uploadHistory.length > 0}}">
    <view class="section-title">上传记录</view>
    <view class="history-list">
      <view class="history-item" wx:for="{{uploadHistory}}" wx:key="index">
        <view class="history-icon-wrapper">
          <text class="history-icon">{{getTypeEmoji(item.type)}}</text>
        </view>
        <view class="history-info">
          <text class="history-title">{{item.title}}</text>
          <text class="history-time">{{item.time}}</text>
        </view>
        <view class="history-status success">已上传</view>
      </view>
    </view>
  </view>
</view>
